generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/* ═══════════════════════════════════════
   Admin - Platform administrators
   ═══════════════════════════════════════ */
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  welcomeMessages WelcomeMessage[]
}

/* ═══════════════════════════════════════
   User - App users
   ═══════════════════════════════════════ */
model User {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?  @unique
  password        String?
  avatar          String?
  xp              Int      @default(0)
  streak          Int      @default(0)
  gems            Int      @default(0)
  level           Int      @default(1)
  lastActiveAt    DateTime?
  onboarded       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments     UserEnrollment[]
  dayProgress     DayProgress[]
  shares          Share[]
}

/* ═══════════════════════════════════════
   Roadmap - Main roadmap container
   ═══════════════════════════════════════ */
model Roadmap {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  type        String   @default("free") // "free" | "paid"
  price       Float?   // price if paid
  status      String   @default("active") // "active" | "draft" | "closed" | "archived"
  sortOrder   Int      @default(0)
  targetAudience String? // who is this for
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks       RoadmapWeek[]
  enrollments UserEnrollment[]
}

/* ═══════════════════════════════════════
   RoadmapWeek - Weeks within a roadmap
   ═══════════════════════════════════════ */
model RoadmapWeek {
  id          String   @id @default(cuid())
  roadmapId   String
  title       String   // e.g. "الأسبوع الأول"
  description String?
  sortOrder   Int      @default(0)
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  days        RoadmapDay[]
}

/* ═══════════════════════════════════════
   RoadmapDay - Days within a week
   ═══════════════════════════════════════ */
model RoadmapDay {
  id          String   @id @default(cuid())
  weekId      String
  title       String   // e.g. "اليوم الأول"
  description String?
  sortOrder   Int      @default(0)
  icon        String?
  xpReward    Int      @default(10) // XP for completing this day
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  week        RoadmapWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  content     ContentItem[]
  progress    DayProgress[]
}

/* ═══════════════════════════════════════
   ContentItem - Content within a day (4 types)
   ═══════════════════════════════════════ */
model ContentItem {
  id          String   @id @default(cuid())
  dayId       String
  type        String   // "youtube_reel" | "game_challenge" | "article" | "task"
  title       String
  description String?
  url         String?  // YouTube URL for reels
  imageUrl    String?
  xpReward    Int      @default(5)
  sortOrder   Int      @default(0)
  settings    String?  // JSON string for extra settings per content type
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  day         RoadmapDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

/* ═══════════════════════════════════════
   UserEnrollment - User enrolled in a roadmap
   ═══════════════════════════════════════ */
model UserEnrollment {
  id          String   @id @default(cuid())
  userId      String
  roadmapId   String
  startedAt   DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
}

/* ═══════════════════════════════════════
   DayProgress - User progress on each day
   ═══════════════════════════════════════ */
model DayProgress {
  id          String   @id @default(cuid())
  userId      String
  dayId       String
  status      String   @default("locked") // "locked" | "active" | "completed"
  xpEarned    Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day         RoadmapDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

/* ═══════════════════════════════════════
   WelcomeMessage - Customizable onboarding messages
   ═══════════════════════════════════════ */
model WelcomeMessage {
  id          String   @id @default(cuid())
  adminId     String?
  title       String
  message     String   // The welcome text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin       Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
}

/* ═══════════════════════════════════════
   Share - User sharing their progress
   ═══════════════════════════════════════ */
model Share {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  message     String?
  imageUrl    String?
  shareKey    String   @unique // unique share URL key
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
